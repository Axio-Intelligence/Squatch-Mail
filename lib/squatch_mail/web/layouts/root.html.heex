<!DOCTYPE html>
<html lang="en" style="background: #f3efe0;">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <meta name="squatch-mail-csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <meta name="squatch-mail-socket-path" content="/live" />
    <title>SquatchMail</title>
    <link
      rel="icon"
      type="image/png"
      href={@dashboard_path <> "/assets/" <> SquatchMail.Web.AssetController.asset_path(:logo)}
    />
    <link rel="stylesheet" href={@dashboard_path <> "/assets/" <> SquatchMail.Web.AssetController.asset_path(:css)} />
    <script defer src={@dashboard_path <> "/assets/" <> SquatchMail.Web.AssetController.asset_path(:js)}>
    </script>
  </head>
  <body>
    <%= @inner_content %>
  </body>
</html>
